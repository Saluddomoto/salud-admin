# ================================================================
# Salud 基幹システム — 環境変数テンプレート
# このファイルをコピーして .env.local を作成してください
# .env.local は絶対にGitにコミットしないでください
# ================================================================

# ----------------------------------------------------------------
# Firebase 設定（Firebaseコンソール > プロジェクト設定 > 全般 から取得）
# ----------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK（Cloud Functions / サーバーサイドのみ）
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_PRIVATE_KEY=
FIREBASE_ADMIN_CLIENT_EMAIL=

# ----------------------------------------------------------------
# LINE 連携（将来: v3）
# LINE Developers コンソールから取得
# ----------------------------------------------------------------
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ----------------------------------------------------------------
# Google Workspace 連携（将来: v2）
# Google Cloud Console から取得
# ----------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ----------------------------------------------------------------
# AI（将来: v4）
# Anthropic コンソールから取得
# ----------------------------------------------------------------
ANTHROPIC_API_KEY=

# ----------------------------------------------------------------
# アプリ設定
# ----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# ================================================================
# Salud 基幹システム — 環境変数テンプレート
# このファイルをコピーして .env.local を作成してください
# .env.local は絶対にGitにコミットしないでください
# ================================================================

# ----------------------------------------------------------------
# Supabase（Dashboard → Settings → API から取得）
# ----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# サーバー専用（LINE Webhook / Cron が RLS をバイパスするために使用。絶対に公開しない）
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------
# Cron（Vercel の環境変数に設定すると Vercel Cron が自動で付与する）
# ----------------------------------------------------------------
CRON_SECRET=

# ----------------------------------------------------------------
# Firebase 設定（旧・未使用。Supabase に移行済み）
# ----------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK（Cloud Functions / サーバーサイドのみ）
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_PRIVATE_KEY=
FIREBASE_ADMIN_CLIENT_EMAIL=

# ----------------------------------------------------------------
# LINE 連携（実装済み — LINE Developers コンソールの Messaging API チャネルから取得）
#   Webhook URL: https://<デプロイ先ホスト>/api/line/webhook
# ----------------------------------------------------------------
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ----------------------------------------------------------------
# Google Workspace 連携（将来: v2）
# Google Cloud Console から取得
# ----------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ----------------------------------------------------------------
# AI（将来: v4）
# Anthropic コンソールから取得
# ----------------------------------------------------------------
ANTHROPIC_API_KEY=

# ----------------------------------------------------------------
# アプリ設定
# ----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
